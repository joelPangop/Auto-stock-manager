# =============================================================================
# AUTO STOCK MANAGER — Variables d'environnement
# =============================================================================
# Ce fichier est chargé automatiquement par Docker Compose (env_file).
# Pour le développement local (sans Docker), copiez ce fichier sous le nom
# .env.local ou configurez ces variables dans votre IDE (Run Configuration).
# NE JAMAIS COMMITTER de vraies valeurs sensibles dans git.
# =============================================================================


# -----------------------------------------------------------------------------
# BASE DE DONNÉES
# -----------------------------------------------------------------------------
# Pour Docker Compose, le host est le nom du service MySQL défini dans compose.
# Pour le dev local (sans Docker), utilisez 127.0.0.1 et le port local (3306).
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/autos_stock_db?createDatabaseIfNotExist=true&allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=Abc123...


# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# Clé secrète HS256 en Base64 (>= 44 caractères).
# Générer une nouvelle clé : openssl rand -base64 64
SECURITY_JWT_SECRET=VGhpcy1pcy1hLXN0cm9uZy1iYXNlNjQtc2VjcmV0LWtleS1jaGFuZ2UtbWUtIQpCMV9OU0RKS1BfQzRzM2JxQ1Q=
# Durée du token d'accès en ms (ex: 900000 = 15 min)
SECURITY_JWT_ACCESS_EXPIRATION=900000
# Durée du token de rafraîchissement en ms (ex: 1209600000 = 14 jours)
SECURITY_JWT_REFRESH_EXPIRATION=1209600000


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Origines autorisées séparées par des virgules.
# Dev local Angular : http://localhost:4200
# Docker Compose   : http://localhost:3000
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200


# -----------------------------------------------------------------------------
# EMAIL (SMTP)
# -----------------------------------------------------------------------------
# Serveur SMTP. Par défaut Gmail. Changer pour votre fournisseur si besoin.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# Adresse Gmail utilisée pour envoyer les emails.
# Activer "Mots de passe d'application" dans votre compte Google :
#   Mon compte Google → Sécurité → Validation en 2 étapes → Mots de passe d'application
MAIL_USERNAME=joelpangop.email@gmail.com
MAIL_PASSWORD=Jojo0689$$$


# -----------------------------------------------------------------------------
# SMS (Twilio) — optionnel
# -----------------------------------------------------------------------------
# Créer un compte sur https://www.twilio.com (gratuit pour les tests).
# Tableau de bord Twilio : https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Numéro Twilio au format E.164 (ex: +12015551234)
TWILIO_FROM_NUMBER=+1XXXXXXXXXX


# -----------------------------------------------------------------------------
# DIVERS
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
